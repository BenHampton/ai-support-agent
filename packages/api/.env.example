# Backend
PORT=3001
DATA_DIR=./data

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen3:8b

# set 'true' to simulate active ArkCloud incident outage
OUTAGE_ACTIVE=true

 # --- Zendesk resilience (all optional; defaults live in src/config.ts) ---
 # Per-call timeout before a ticket create is treated as failed (ms)
 ZENDESK_TIMEOUT_MS=4000
 # Retries on a retryable failure (timeout / 5xx) before falling back to the durable outbox
 ZENDESK_MAX_RETRIES=2
 # Consecutive failures that trip the circuit breaker open
 ZENDESK_BREAKER_THRESHOLD=5
 # How long the breaker stays open before a probe attempt (ms)
 ZENDESK_BREAKER_COOLDOWN_MS=30000
 # How often the reconciler drains queued escalations into Zendesk (ms)
 RECONCILER_INTERVAL_MS=10000
 # Simulate a Zendesk outage from startup (true/false); also toggled live via POST /admin/zendesk/down
 ZENDESK_DOWN=false
 # Token required on /admin/* endpoints; if unset the admin routes are open (local dev only)
 ADMIN_TOKEN=
